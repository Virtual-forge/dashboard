+-- Human-readable tool descriptions, kept in a table WE own, living in the
+-- same `ai` schema as Agno's own tables for consistency (but a separate
+-- table — we never touch ai.agno_approvals itself). The backend LEFT JOINs
+-- this onto ai.agno_approvals by tool_name at read time. Populate it by
+-- running
+--   python sync_tool_descriptions.py
+-- any time you add/rename a tool, or upsert rows by hand.
+CREATE TABLE IF NOT EXISTS ai.tool_descriptions (
+    tool_name TEXT PRIMARY KEY,
+    description TEXT NOT NULL,
+    updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
+);
